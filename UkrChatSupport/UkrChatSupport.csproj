<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Dalamud.NET.Sdk/14.0.2">
  <PropertyGroup>
    <RootNamespace>UkrChatSupport</RootNamespace>
    <AssemblyName>UkrChatSupport</AssemblyName>
    <Version>1.0.0</Version>
    <Description>Support for Ukrainian characters in FFXIV text chat and input field.</Description>
    <PackageProjectUrl>https://github.com/richtertarnished/ukr_chat</PackageProjectUrl>
    <PackageLicenseExpression>AGPL-3.0-or-later</PackageLicenseExpression>
    <IsPackable>false</IsPackable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
</Project>
